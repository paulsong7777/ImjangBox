<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.imjangbox.facility.FacilityTemplateMapper">
    <resultMap id="facilityTemplateItem" type="com.imjangbox.facility.FacilityTemplateItem">
        <constructor>
            <arg column="business_type" javaType="String"/>
            <arg column="item_key" javaType="String"/>
            <arg column="label" javaType="String"/>
            <arg column="display_order" javaType="int"/>
            <arg column="customer_visible" javaType="boolean"/>
        </constructor>
    </resultMap>

    <select id="findTemplateItemsByBusinessType" resultMap="facilityTemplateItem">
        SELECT business_type,
               item_key,
               label,
               display_order,
               customer_visible
          FROM facility_check_templates
         WHERE active = TRUE
           AND business_type = #{businessType}
         ORDER BY display_order, item_key
    </select>

    <select id="findBusinessTypes" resultType="String">
        SELECT DISTINCT business_type
          FROM facility_check_templates
         WHERE active = TRUE
         ORDER BY business_type
    </select>
</mapper>
